version: "3.9"

services:
  adguard_exporter:
    image: ghcr.io/henrywhitaker3/adguard-exporter:v1.2.1
    environment:
      ADGUARD_SERVERS: "http://10.151.14.4:8000"
      ADGUARD_USERNAMES: "{{ adguard_username }}"
      ADGUARD_PASSWORDS: "{{ adguard_password }}"
    ports:
      - target: 9618
        published: 9618
        protocol: tcp
        mode: host
    deploy:
      replicas: {{ rpi_monitoring_adguard_exporter_replicas | default(1) }}
      update_config:
        order: start-first
        failure_action: rollback
      rollback_config:
        order: stop-first
      restart_policy:
        condition: any
        delay: 5s
        max_attempts: 5
      placement:
        constraints:
          - node.role == manager

  gatus:
    image: twinproduction/gatus:v5.36.0
    volumes:
      - /opt/gatus/config:/config
      - /opt/gatus/data:/data
    ports:
      - target: 8080
        published: 8080
        protocol: tcp
        mode: host
    deploy:
      replicas: {{ rpi_monitoring_gatus_replicas | default(1) }}
      update_config:
        order: start-first
        failure_action: rollback
      rollback_config:
        order: stop-first
      restart_policy:
        condition: any
        delay: 5s
        max_attempts: 5
      placement:
        constraints:
          - node.role == manager

  alloy:
    image: grafana/alloy:v1.17.1
    volumes:
      - /opt/alloy/config:/etc/alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /:/host/root:ro
      - /sys:/host/sys:ro
      - /proc:/host/proc:ro
      - /var/log:/host/var/log:ro
      - /run/udev:/host/udev:ro
    command:
      - run
      - /etc/alloy/config.alloy
      - --server.http.listen-addr=0.0.0.0:12345
      - --storage.path=/var/lib/alloy/data
      - --disable-reporting
    ports:
      - target: 12345
        published: 12345
        protocol: tcp
        mode: host
    privileged: true
    deploy:
      mode: global
      update_config:
        order: start-first
        failure_action: rollback
      rollback_config:
        order: stop-first
      restart_policy:
        condition: any
        delay: 5s
        max_attempts: 5

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.55.1
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:rw
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    devices:
      - /dev/kmsg:/dev/kmsg
    ports:
      - target: 8080
        published: 8081
        protocol: tcp
        mode: host
    privileged: true
    deploy:
      mode: global
      update_config:
        order: start-first
        failure_action: rollback
      rollback_config:
        order: stop-first
      restart_policy:
        condition: any
        delay: 5s
        max_attempts: 5

networks:
  default:
    name: rpi_monitoring_overlay
    driver: overlay
