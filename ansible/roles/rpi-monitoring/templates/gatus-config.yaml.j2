storage:
  type: sqlite
  path: /data/data.db

ui:
  header: BanceTech Service Status
  link: "https://gatus.{{ inventory_hostname }}.heimelska.co.uk"
  default-sort-by: group
  buttons:
{% for host in groups['rpi'] if host != inventory_hostname %}
    - name: {{ host }}
      link: "https://gatus.{{ host }}.heimelska.co.uk"
{% endfor %}

{% set discord_webhook = gatus_discord_webhook_url | default('') | trim %}
{% set discord_enabled = discord_webhook | length > 0 %}
{% if discord_enabled %}
alerting:
  discord:
    webhook-url: "{{ discord_webhook }}"
    title: ":helmet_with_white_cross: Gatus ({{ inventory_hostname }})"
    message-content: "@bancey"
{% endif %}

endpoints:
  - name: thanos
    group: hosts
    url: "tcp://thanos.heimelska.co.uk:22"
    interval: 1m
    conditions:
      - "[CONNECTED] == true"
      - "[IP] == 10.151.14.5"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
  - name: gamora
    group: hosts
    url: "tcp://gamora.heimelska.co.uk:22"
    interval: 1m
    conditions:
      - "[CONNECTED] == true"
