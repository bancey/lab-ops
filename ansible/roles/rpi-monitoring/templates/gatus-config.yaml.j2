      - "[IP] == 10.151.14.11"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
  - name: wanda-mgmt
    group: hosts
    url: "tcp://10.151.14.10:443"
    interval: 1m
    conditions:
      - "[CONNECTED] == true"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
  - name: aguard dns external
    group: services
    url: "10.151.14.4"
    dns:
      query-name: "google.co.uk"
      query-type: "A"
    conditions:
      - "[DNS_RCODE] == NOERROR"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
  - name: adguard dns internal
    group: services
    url: "10.151.14.4"
    dns:
      query-name: "hass.tiny.heimelska.co.uk"
      query-type: "A"
    conditions:
      - "[DNS_RCODE] == NOERROR"
      - "[BODY] == 10.151.24.10"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
  - name: home assistant
    group: services
    url: "https://hass.tiny.heimelska.co.uk"
    interval: 1m
    conditions:
      - "[STATUS] == 200"
      - "[BODY] == pat(*<title>Home Assistant</title>*)"
{% if discord_enabled %}
    alerts:
      - type: discord
        send-on-resolved: true
{% endif %}
