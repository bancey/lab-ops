# PostgreSQL Client Authentication Configuration - Managed by Ansible
# {{ ansible_managed }}

# TYPE  DATABASE        USER            ADDRESS                 METHOD

# Local connections
local   all             all                                     peer
local   all             postgres                                peer

# IPv4 local connections
host    all             all             127.0.0.1/32            scram-sha-256

# Replication connections from cluster nodes
{% for node_ip in postgresql_nodes %}
host    replication     replicator      {{ node_ip }}/32        scram-sha-256
{% endfor %}

# Application connections from any host (authenticated)
host    all             all             10.151.14.0/24          scram-sha-256

# PgBouncer connections from localhost
host    all             all             127.0.0.1/32            scram-sha-256
host    all             pgbouncer       127.0.0.1/32            scram-sha-256
